{
  "name": "xpensify-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed-runner.ts",
    "pretest": "node ../scripts/check-node.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@hono/node-server": "^2.0.4",
    "@types/js-yaml": "^4.0.9",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.1",
    "hono": "^4.12.25",
    "js-yaml": "^4.2.0",
    "node-cron": "^4.2.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.8",
    "sharp": "^0.35.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
