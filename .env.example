SESSION_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
# Optional. Public iCloud Shortcut URL for one-tap install on iPhone.
# Build-time only — baked into the client bundle. Unset → Settings shows
# a placeholder explaining the deployer needs to publish their own.
VITE_APPLE_SHORTCUT_URL=
# Optional. When set, the Apple Pay webhook calls Gemini Flash to suggest a
# category for never-seen merchants (gemini-3-flash-preview, low thinking).
# Unset → the suggestion path is a silent no-op; pending rows are created
# without a category and the user picks one in Confirm as before.
GEMINI_API_KEY=
DB_PATH=./data/xpensify.db
PORT=3000
# Public hostname (e.g. expenses.example.com). Used by the CSRF middleware
# to validate the Origin header on mutations. Leave UNSET in local dev so
# the Vite proxy works; SET in production or CSRF defense is disabled.
DOMAIN=
# Daily SQLite snapshot directory. Cron runs at 03:30, retention 14 days.
# Unset → backups disabled. In Docker, point at a path inside /app/data so
# it lands in the mounted volume (e.g. /app/data/backups).
BACKUP_DIR=/app/data/backups

# Initial seed passwords for the users defined in config/users.yaml.
# Env var name is <USERNAME_UPPERCASE>_PASSWORD. If unset on first seed,
# a UUID is generated and printed to stdout once.
ALICE_PASSWORD=
BOB_PASSWORD=
