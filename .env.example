SESSION_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
# Optional. When set, the Apple Pay webhook calls Gemini Flash to suggest a
# category for never-seen merchants (gemini-3-flash-preview, low thinking).
# Unset → the suggestion path is a silent no-op; pending rows are created
# without a category and the user picks one in Confirm as before.
GEMINI_API_KEY=
DB_PATH=./data/xpensify.db
PORT=3000
DOMAIN=your-domain.com
BACKUP_DIR=./backups

# Initial seed passwords — used only on first seed run (skipped if user already exists).
# Leave unset to have random passwords generated and printed to the seed log.
ALICE_PASSWORD=
BOB_PASSWORD=
